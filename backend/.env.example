# MongoDB Atlas — replace <db_password>; URL-encode special chars in password (e.g. @ -> %40)
# Direct hosts (no SRV DNS); replicaSet from Atlas. Database path: /neurohire (match your app)
MONGO_URI=mongodb://f223873:<db_password>@ac-jnce3rd-shard-00-00.nftaz6m.mongodb.net:27017,ac-jnce3rd-shard-00-01.nftaz6m.mongodb.net:27017,ac-jnce3rd-shard-00-02.nftaz6m.mongodb.net:27017/neurohire?ssl=true&replicaSet=atlas-a8f5ql-shard-0&authSource=admin&appName=NeuroHire&retryWrites=true&w=majority

# Server
PORT=5000

# Frontend URL (for CORS) - update when deploying
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# Backend URL - update when deploying
BACKEND_URL=http://localhost:5000

# Bytez LLM (default model: google/gemma-3-1b-it; override with BYTEZ_MODEL)
BYTEZ_API_KEY=your_bytez_api_key
# BYTEZ_MODEL=google/gemma-3-1b-it
# Set to 1 if your Bytez model errors on max_completion_tokens (auto-skipped for gemma)
# BYTEZ_DISABLE_MAX_COMPLETION_TOKENS=1

# Admin JWT (optional, for admin panel)
ADMIN_JWT_SECRET=your_random_secret

# n8n webhooks (optional)
# N8N_EMAIL_WEBHOOK_URL=
# N8N_WEBHOOK_URL=


